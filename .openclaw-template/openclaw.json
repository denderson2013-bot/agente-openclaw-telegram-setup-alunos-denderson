      "telegram",
      "discord",
      "whatsapp",
      "zai",
      "anthropic",
      "openai-codex",
      "browser"
    ],
    "slots": {
      "memory": "openclaw-mem0"
    },
    "entries": {
      "openclaw-mem0": {
        "enabled": true,
        "config": {
          "mode": "open-source",
          "oss": {
            "llm": {
              "provider": "openai",
              "config": {"model": "gpt-4o-mini"}
            },
            "embedder": {
              "provider": "openai",
              "config": {
                "model": "text-embedding-3-small",
                "embeddingDims": 1536
              }
            },
            "vectorStore": {
              "provider": "pgvector",
              "config": {
                "connectionString": "{{MEM0_DB_URL}}",
                "tableName": "mem0_memories",
                "embeddingDims": 1536
              }
            }
          }
        }
      },
      "memory-core": {"enabled": false},
      "memory-lancedb": {"enabled": false},
      "zai": {"enabled": true, "config": {}},
      "openai-codex": {"enabled": true, "config": {}},
      "telegram": {"enabled": true},
      "discord": {"enabled": false},
      "whatsapp": {"enabled": false},
      "anthropic": {"enabled": true},
      "browser": {"enabled": true}
