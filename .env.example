# ============================================
# .env.example -- OpenClaw ORIGINAL puro + Telegram (v2)
# ============================================
# Copia pra /root/.openclaw/.env (Linux) ou ~/.openclaw/.env (Mac).
# So e necessario se voce vai usar audio (Whisper / ElevenLabs).
# O resto (LLM, Telegram) fica no openclaw.json.
# chmod 600 .env -- NUNCA committar com secrets reais.
# ============================================

# ----- AUDIO DE ENTRADA (opcional) -----
# Chave OpenAI: transcreve audios do Telegram via Whisper.
OPENAI_API_KEY=

# ----- AUDIO DE SAIDA (opcional) -----
# ElevenLabs: voz natural nas respostas em audio.
# (apiKey + voiceId tambem podem ficar em messages.tts no openclaw.json)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ============================================
# NAO vai aqui (fica no openclaw.json):
#   - Telegram bot token / user_id        -> channels.telegram
#   - GLM (Z.ai) baseUrl / apiKey / model  -> models.providers.zai + 'openclaw models set'
#   - GPT Codex 5.5                         -> OAuth via 'openclaw models auth login --provider openai --device-code'
#                                             (sem API key, gasta da assinatura ChatGPT Plus)
# ============================================
