# ============================================
# .env.example -- Template v1 (OpenClaw + Telegram)
# ============================================
# Copia pra /root/.openclaw/.env (Linux) ou ~/.openclaw/.env (Mac)
# Substitui placeholders {{...}} pelos valores reais
# chmod 600 .env (NUNCA committar com secrets reais)
# ============================================

# ----- AGENTE BASICO (obrigatorio) -----
AGENTE_NAME={{AGENTE_NAME}}
OWNER_NAME={{OWNER_NAME}}

# ----- BACKEND LLM ESCOLHIDO (obrigatorio) -----
# Opcoes: "glm" ou "gpt-codex"
LLM_BACKEND={{LLM_BACKEND}}

# ----- GLM 4.5/5 TURBO via Z.AI (se LLM_BACKEND=glm) -----
ZAI_API_KEY={{ZAI_API_KEY}}
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_API_MODE=openai-completions

# ----- GPT CODEX 5.5 via OPENAI CODEX CLI (se LLM_BACKEND=gpt-codex) -----
# OAuth -- nao precisa key aqui, openclaw guarda token apos login
OPENAI_CODEX_OAUTH_EMAIL={{OPENAI_CODEX_OAUTH_EMAIL}}

# ----- ANTHROPIC (fallback opcional, OAuth via Claude Code CLI) -----
# Auth via 'claude auth login --claudeai'

# ----- TELEGRAM (obrigatorio) -----
TELEGRAM_BOT_TOKEN={{TELEGRAM_BOT_TOKEN}}
TELEGRAM_USER_ID_DONO={{TELEGRAM_USER_ID_DONO}}
TELEGRAM_BOT_USERNAME={{TELEGRAM_BOT_USERNAME}}

# ----- POSTGRESQL (gerado pelo SETUP) -----
DATABASE_URL=postgres://openclaw:{{PG_PASSWORD}}@127.0.0.1:5432/openclaw_memory
MEM0_DB_URL=postgres://openclaw:{{PG_PASSWORD}}@127.0.0.1:5432/openclaw_memory

# ----- AUDIO BIDIRECIONAL (opcional) -----
OPENAI_API_KEY={{OPENAI_API_KEY}}
ELEVENLABS_API_KEY={{ELEVENLABS_API_KEY}}
ELEVENLABS_VOICE_ID={{ELEVENLABS_VOICE_ID}}

# ----- DISCORD (opcional) -----
DISCORD_BOT_TOKEN={{DISCORD_BOT_TOKEN}}
DISCORD_USER_ID_DONO={{DISCORD_USER_ID_DONO}}

# ----- SKILLS (opcional) -----
GOPLACES_API_KEY={{GOOGLE_MAPS_KEY_PLACES_GEOCODING}}
SAG_API_KEY={{SAG_API_KEY}}

# ----- GATEWAY (gerado pelo SETUP) -----
OPENCLAW_GATEWAY_TOKEN={{OPENCLAW_GATEWAY_TOKEN}}
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=loopback

# ----- DEPLOY PUBLICO (opcional) -----
GITHUB_TOKEN={{GITHUB_PAT_PARA_DEPLOY}}
VERCEL_TOKEN={{VERCEL_TOKEN}}
CLOUDFLARE_API_TOKEN={{CLOUDFLARE_DNS_TOKEN}}
CLOUDFLARE_ZONE_ID={{CLOUDFLARE_ZONE_ID}}

# ----- HEARTBEAT -----
HEARTBEAT_INTERVAL=3600
DAILY_REPORT_HOUR=9
DAILY_REPORT_TIMEZONE=America/Sao_Paulo

# ----- IDENTIDADE DO AGENTE -----
PRODUTO_DONO={{PRODUTO_DONO}}
NICHO_DONO={{NICHO_DONO}}
INSTAGRAM_HANDLE_DONO={{INSTAGRAM_HANDLE_DONO}}
DOMINIO_PRINCIPAL={{DOMINIO_PRINCIPAL}}
